{% comment %}
  dependant-selector.liquid — App Block (target: section)
  This block can be added specifically to the product page via the Theme Editor.
{% endcomment %}

<div 
  id="dep-block-root" 
  class="dep-block-root"
  data-block-id="{{ block.id }}"
  data-heading="{{ block.settings.heading | escape }}"
>
  {% comment %} The JS will inject the widget here if this element exists {% endcomment %}
</div>

{% schema %}
{
  "name": "Dependant Selector",
  "target": "section",
  "templates": ["product"],
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Add / Select Your Dependant"
    }
  ]
}
{% endschema %}
